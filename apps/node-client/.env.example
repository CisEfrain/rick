SESSION_ID=raspi-001
BRIDGE_WS_URL=ws://localhost:3000
# Token for WS auth (must match server INTERNAL_TOKEN)
TOKEN=change_me_to_a_strong_secret

# ── Plataforma ──
# "raspi" para Raspberry Pi / Windows nativo, "emulator" para emulador con browser
PLATFORM=raspi

# Audio backend: 'sox' (Windows) or 'arecord' (Linux/Raspi). Auto-detected by OS if not set.
# Solo aplica cuando PLATFORM=raspi
AUDIO_BACKEND=sox
# Full path to sox.exe — only required on Windows when AUDIO_BACKEND=sox
SOX_PATH=C:\Users\Admin\AppData\Local\Microsoft\WinGet\Packages\ChrisBagwell.SoX_Microsoft.Winget.Source_8wekyb3d8bbwe\sox-14.4.2\sox.exe

# Set to 'true' to mute the mic while Rick is speaking (prevents echo on speakers).
# Disable when using hardware echo cancellation (e.g. ReSpeaker HAT).
MUTE_MIC_WHILE_SPEAKING=true

# Extra delay (ms) after speaker finishes before re-enabling mic. Increase if echo persists. Default: 500
PLAYBACK_DONE_DELAY_MS=500

# ── Emulador (solo aplica cuando PLATFORM=emulator) ──
# Puerto del WebSocket local que conecta el Node Client con el frontend React
FRONTEND_WS_PORT=3001
