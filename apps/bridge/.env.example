BRIDGE_PORT=3000
DEEPGRAM_API_KEY=your_deepgram_api_key_here
INTERNAL_TOKEN=change_me_to_a_strong_secret
N8N_TOOL_WEBHOOK_URL=http://localhost:5678/webhook/tool

# Ms of silence (no audio chunks) after which the mic is re-enabled.
# Increase if echo persists (slower speakers). Default: 800
AUDIO_SILENCE_TIMEOUT_MS=800

# Safety timeout (ms) to unblock mic if client never sends playback.done.
# Should be longer than the longest expected agent response. Default: 15000
PLAYBACK_DONE_TIMEOUT_MS=15000
