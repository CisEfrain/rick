BRIDGE_PORT=3000
DEEPGRAM_API_KEY=your_deepgram_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
INTERNAL_TOKEN=change_me_to_a_strong_secret
N8N_TOOL_WEBHOOK_URL=http://localhost:5678/webhook/tool

# STT config (Deepgram Nova-3 streaming)
STT_MODEL=nova-3
STT_LANGUAGE=es
# Ms of inactivity before closing the STT session to save API credits.
# Session reconnects automatically when the user speaks again. Default: 120000 (2 min)
STT_IDLE_TIMEOUT_MS=120000
# Ms of silence before Deepgram considers an utterance complete (VAD).
# Deepgram minimum is 1000. Default: 1000
STT_UTTERANCE_END_MS=1000

# LLM config (OpenAI GPT)
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.8

# TTS config (Deepgram Aura-2)
TTS_MODEL=aura-2-alvaro-es
TTS_SAMPLE_RATE=16000

# Weather API (optional, for obtener_clima tool)
WEATHER_API_KEY=

# Memory storage path (default: data/memory)
MEMORY_DIR=data/memory
